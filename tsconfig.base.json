{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@npm-burst/github-data-access": [
        "libs/github-data-access/src/index.ts"
      ],
      "@npm-burst/npm-data-access": [
        "libs/npm-data-access/src/index.ts"
      ]
    },
    "strict": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "tmp"]
}
