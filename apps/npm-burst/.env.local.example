# Trips the local-only auth bypass in src/server/auth.ts so telefuncs
# resolve a userId without a Clerk session. Keep this only in
# .env.local — never set it in wrangler.toml [vars] (would leak to
# prod and make every request a logged-in user).
DEV_MODE=true

VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=...
CLERK_PUBLISHABLE_KEY=...
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GITHUB_APP_ID=1234567
GITHUB_APP_SLUG=npm-burst
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace-me
