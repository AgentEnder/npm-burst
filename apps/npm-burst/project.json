{
  "name": "npm-burst",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/npm-burst/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "command": "vite build",
      "options": { "cwd": "apps/npm-burst" },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/apps/web"]
    },
    "serve": {
      "command": "vite",
      "options": { "cwd": "apps/npm-burst" },
      "continuous": true
    },
    "test": {
      "command": "vitest",
      "options": { "cwd": "apps/npm-burst" },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "deploy": {
      "command": "wrangler pages deploy",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/npm-burst"
      }
    },
    "db:migrate": {
      "command": "tsx src/server/migrate.ts",
      "options": { "cwd": "apps/npm-burst" }
    },
    "db:codegen": {
      "command": "kysely-codegen --dialect sqlite --url file:local.db --out-file src/server/db-schema.ts",
      "options": { "cwd": "apps/npm-burst" },
      "dependsOn": ["db:migrate"]
    },
    "db:generate": {
      "command": "TURSO_DATABASE_URL=file:local.db tsx src/server/migrate.ts && kysely-codegen --dialect sqlite --url ./local.db --out-file src/server/db-schema.ts",
      "options": { "cwd": "apps/npm-burst" }
    }
  }
}
